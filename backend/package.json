{
  "name": "jmeter-llm-toolkit-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--openssl-legacy-provider tsx watch src/server.ts",
    "build": "tsc -p .",
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider node dist/server.js"
  },
  "dependencies": {
    "@seald-io/nedb": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fast-xml-parser": "^4.4.1",
    "mongodb": "^6.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "cross-env": "^7.0.3",
    "pkg": "^5.8.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "bin": "dist/server.js",
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "../frontend/dist/**/*",
      "data/**/*",
      ".env"
    ],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "../release"
  }
}