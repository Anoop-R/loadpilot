# Copy this file to .env and fill in your key. This is the ONLY thing you need to add.
GROQ_API_KEY=your_groq_api_key_here

# Optional overrides
GROQ_MODEL=llama-3.3-70b-versatile
PORT=4000

# Optional: add a MongoDB connection string to persist run history and saved
# configs in a real database instead of local files. Leave both blank to keep
# using local files — everything works fine either way.
MONGODB_URI=
MONGODB_DB_NAME=loadpilot

# If you see "SSL alert number 80" when connecting to MongoDB Atlas on Node 20,
# add this line to your .env and restart — it fixes a known OpenSSL 3.x
# compatibility issue with Atlas's TLS negotiation:
# NODE_OPTIONS=--openssl-legacy-provider
